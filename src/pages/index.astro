---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 3em 0 2em;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2em;
			}
			.hero h1 {
				margin: 0 0 0.4em;
				font-size: 2.5em;
				line-height: 1.1;
			}
			.hero p {
				margin: 0 0 1.5em;
				color: rgb(var(--gray));
				font-size: 1.1em;
				max-width: 520px;
			}
			.cta {
				display: inline-block;
				color: var(--accent);
				font-weight: 600;
				text-decoration: none;
				border-bottom: 2px solid var(--accent);
				padding-bottom: 2px;
			}
			.cta:hover {
				color: var(--accent-dark);
				border-bottom-color: var(--accent-dark);
			}
			h2 {
				font-size: 1em;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: rgb(var(--gray));
				margin: 0 0 1em;
			}
			ul {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 0;
			}
			ul li a {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1em;
				padding: 0.9em 0;
				border-bottom: 1px solid rgb(var(--gray-light));
				text-decoration: none;
				color: rgb(var(--black));
			}
			ul li a:hover .title {
				color: var(--accent);
			}
			.title {
				font-weight: 600;
				line-height: 1.3;
			}
			.date {
				flex-shrink: 0;
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			@media (max-width: 720px) {
				ul li a {
					flex-direction: column;
					gap: 0.2em;
				}
				.hero h1 {
					font-size: 1.8em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>UX & Design Digest</h1>
				<p>Daily stories on UX research, product design, and AI in product — curated and written automatically.</p>
				<a href="/blog" class="cta">Browse all posts →</a>
			</section>
			{posts.length > 0 && (
				<section>
					<h2>Recent</h2>
					<ul>
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="title">{post.data.title}</span>
									<span class="date"><FormattedDate date={post.data.pubDate} /></span>
								</a>
							</li>
						))}
					</ul>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>
